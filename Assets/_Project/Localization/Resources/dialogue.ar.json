  // ─────────────────────────────────────────────────────────────────
  // Hearthbound Hollow — جدول الحوار العربي
  // المرحلة 60 — تَعريبُ المَهمَّتَين الأولى والثانية
  //
  // طريقةُ اللُّوكَب:
  //   كلُّ مفتاحٍ هو نفس الـ lineId المُستَخدَم في:
  //     • Mission01Director.cs / Mission02Director.cs (نِداء Line)
  //     • Tools/generate_voices.sh  (لتوليد ملفّات الصوت)
  //     • VoiceLibrarySO  (لرَبط الصوت بالنّص)
  //
  // قاعدةُ الترجمة:
  //   • نَحفظُ صَوتَ الشخصيّة (Vellis Rules لِدوريس، Cordray لِجيرولد):
  //       - دوريس: استعاراتٌ خبزيّة، جُمَلٌ قصيرة (~12 كلمة)، دفءٌ غير مُتَكَلَّف.
  //       - جيرولد: اعتذارٌ مُتكرّر، نَفَسُ نَجّار، "الجزء الطويل" تَحَوَّلَ إلى
  //         «الجزء الطويل» كَعِبارةٍ ثابتة (ليست استعارةً، بل رُكنٌ معجَميّ).
  //       - مارين: هَمسٌ كأنّه قراءةٌ بصوتٍ خافت.
  //       - بيكل: إيجازٌ ذَكيٌّ ساخر، خَطٌّ مائلٌ في الـ UI.
  //       - الراوي: فُصحى أدبيّة، حياديّة، تَقدِيمٌ كأنّه مَطلَعُ فصل.
  // ─────────────────────────────────────────────────────────────────

  // ╔══════════════════════════════════════════════════════════════╗
  // ║  DORIS — MISSION 1 (55 سَطر)                                  ║
  // ╚══════════════════════════════════════════════════════════════╝

  // التَّحيَة
  "doris_m1_greet_01":                  "أنتَ الجديد.",
  "doris_m1_greet_02":                  "كنتُ أحسَبُكَ أَطوَل.",
  "doris_m1_greet_03":                  "لا تُؤاخِذني — كنتُ أحسَبُ الأمرَ نفسَه عن القديم.",
  "doris_m1_greet_04":                  "ادخُل. الإبريقُ تَوًّا تَوَقَّفَ عن الغَلَيان.",

  // ردُّها على «هل أنتِ دوريس؟»
  "doris_m1_reply_help_01":             "أَجَل. الواحِدةُ ذاتُها.",
  "doris_m1_reply_help_02":             "وَضَعوا اسمي على اللافِتَة وكلَّ شيء. اُنظر — هناك.",

  // ردُّها على الإيماءة الصامتة
  "doris_m1_reply_silent_01":           "هادِئٌ إذًا. جيّد.",
  "doris_m1_reply_silent_02":           "الخُبزُ يُحِبُّ الهُدوء.",

  // ردُّها على «مَنِ القديم؟»
  "doris_m1_reply_unsure_01":           "… مم.",
  "doris_m1_reply_unsure_02":           "تلكَ مُحادَثَةُ يومٍ أَطوَل.",
  "doris_m1_reply_unsure_03":           "ادخُل. الشايُ أوّلًا.",

  // دُخولُ المَخبَز
  "doris_m1_kitchen_01":                "احذَرِ الطَّحين.",
  "doris_m1_kitchen_02":                "لم أَكنُس منذُ الثلاثاء. أَنوي ذلكَ دائمًا.",
  "doris_m1_kitchen_03":                "… المَتجَرُ المُجاوِرُ لكَ. الجَوْف.",
  "doris_m1_kitchen_04":                "كنتُ أَحفَظُ مفتاحَه لكَ.",

  // تمهيدُ «أوّلُ زَبون»
  "doris_m1_offer_01":                  "… لديَّ شيءٌ لك. قَبلَ أن تَدخُل.",
  "doris_m1_offer_02":                  "أَوَدُّ أن أكونَ أوّلَ زبائنِك، إن سَمَحت.",

  // عَرضُ الذِّكرى الأيقوني
  "doris_m1_memory_01":                 "هذهِ هي الذِّكرى.",
  "doris_m1_memory_02":                 "أَمسِكها كأنَّكَ تُمسِكُ رغيفًا ساخنًا. ليس من الجانب. مِن أَسفَل.",
  "doris_m1_memory_03":                 "إنّها شَيءٌ صغير.",
  "doris_m1_memory_04":                 "أوّلُ مرَّةٍ خَبَزتُ خبزًا لم يُخجِلني.",
  "doris_m1_memory_05":                 "في أكثرِ أيّامي أُفَكِّرُ فيها.",
  "doris_m1_memory_06":                 "أَوَدُّ أن أَضَعَها جانبًا، بُرهَةً.",
  "doris_m1_memory_07":                 "أَتَأخُذُها؟",

  // مَسارُ التَّأجيل / الرَّفض
  "doris_m1_defer_01":                  "أَجَل. ليسَ كُلُّ يومٍ هو ذلكَ اليوم.",
  "doris_m1_defer_02":                  "سأكونُ هنا حين يَحينُ يومُك.",

  // استِطرادُ «أوّلُ الأرغِفَة» (عُمرُها 24)
  "doris_m1_story_01":                  "كنتُ في الرابعةِ والعشرين.",
  "doris_m1_story_02":                  "كان الفُرنُ جديدًا. كان الطُّوبُ جديدًا. كنتُ جديدةً.",
  "doris_m1_story_03":                  "كنتُ أَخبزُ خُبزَ الآخرينَ منذُ تِسعِ سنوات.",
  "doris_m1_story_04":                  "ذاكَ الصَّباحُ كان أوّلَ صَباحٍ يَخُصُّني وحدي.",
  "doris_m1_story_05":                  "أَوَدُّ أن أَستريحَ من حَملِها. لا غَير.",

  // تَمهيدُ السِّعر + الفُروع الثلاثة
  "doris_m1_price_01":                  "أربعةُ نُحاسات، إن سألتَ.",
  "doris_m1_price_02":                  "ذِكرى صغيرة. لن أَدعَكَ تَدفَعُ أكثرَ مِمّا تَستَحِق في أوّلِ يومٍ لك.",
  "doris_m1_price_fair":                "أَجَل. أَشكُرُك.",
  "doris_m1_price_high_01":             "هذا أكثرُ مِمّا يَنبَغي. لن أَدَعَكَ تُورِّطُ نفسَك.",
  "doris_m1_price_high_02":             "خُذها. — حَسَنًا. خُذ بَعضَها.",
  "doris_m1_price_high_03":             "خَمسةٌ إذًا. نِهائيّ.",
  "doris_m1_price_low_01":              "…",
  "doris_m1_price_low_02":              "أَجَل، يَفي بالغَرَض. أَحضِرِ البَقيَّةَ حِينَ تَجِدها.",

  // المُناوَلة («القطّةُ راقَبَتني»)
  "doris_m1_handover_01":               "هُنا.",
  "doris_m1_handover_02":               "أَرَتني الصاحبةُ القديمةُ كيفَ أَصنَعُها. كَلَّفَتني أَربعَ مُحاوَلات.",
  "doris_m1_handover_03":               "كَسَرتُ الثَّلاثَ الأُوَل. القطّةُ راقَبَتني. حَكَمَت عليَّ، أَظُنّ.",
  "doris_m1_handover_04":               "سأكونُ في المَخبَزِ إن أرَدتَني. اطرُق مَرَّتَين.",
  "doris_m1_handover_05":               "ثَمَّةَ إبريقٌ على الطاولة. احذَرِ الفُرنَ الخَشَبيّ — يَعَضّ.",

  // مُراقبَةُ التلميع + ما بَعده + النوم
  "doris_m1_polish_watch":              "سأَنتَظِر. خُذ وقتَك، أيُّها الكَيِّل.",
  "doris_m1_polish_done_01":            "أَجَل.",
  "doris_m1_polish_done_02":            "ها هي. هذا هو الصَّباح.",
  "doris_m1_polish_sleep_01":           "نَمِ اللَّيلَة. الأَحلامُ تأتي.",
  "doris_m1_polish_sleep_02":           "سَأَراكَ ثانيةً، يَومًا ما.",

  // مَسارُ الرَّفض الجَديد
  "doris_m1_refused_01":                "المَتجَرُ ما زالَ لَك.",
  "doris_m1_refused_02":                "ادخُل. اِجلِس بُرهَة. الإبريقُ يَغلي.",
  "doris_m1_refused_03":                "سأكونُ هنا حِينَ تَكونُ جاهزًا.",

  // ما بَعدَ التلميع: ثلاثُ تَفاريع
  "doris_m1_polish_after_perfect":      "صَنَعتَها أَنقى مِمّا أَذكُرُها. أَظُنُّكَ سَتَنفَع.",
  "doris_m1_polish_after_acceptable":   "صَنَعتَها برِفق. ذاكَ ما يَهُمّ.",
  "doris_m1_polish_after_mild":         "… ما زال الصَّباحُ صَباحًا. أَخفَتَ قليلًا. ولكنّه لي. أوّلُ الأيّامِ هكذا. لن أُؤاخِذَك.",

