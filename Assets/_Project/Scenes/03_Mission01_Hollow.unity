  m_Script: {fileID: 11500000, guid: 030e9015ef7940e0ae65815c5079121e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: HearthboundHollow.Mission::HearthboundHollow.Mission.EchoHologramInteractable
  promptText: Interact
  promptWorldOffsetY: 1.2
  enabledForInteraction: 1
  hologramId: marin_welcome_01
  promptFirst: Listen to the Echo
  promptRepeat: Listen again
  line01: "If the Hollow lit again, I am very sorry. You inherit it the way I did
    \u2014 without ceremony, without a manual."
  line02: There is a candle on the workbench. There is a cat at your knee. There
    is a baker next door who has been waiting.
  line03: "Trust the bread. Polish slowly. And if Pickle sniffs a memory and walks
    away \u2014 you should walk away too."
  voiceLineIdA: echo_marin_welcome_01
  voiceLineIdB: echo_marin_welcome_02
  voiceLineIdC: echo_marin_welcome_03
  chordSfxId: echo_marin_chord
