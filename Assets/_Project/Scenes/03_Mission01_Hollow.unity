  hologramLight: {fileID: 1686703891}
  dialogueUI: {fileID: 0}
  hologramGroup: {fileID: 520561913}
  fadeInDuration: 1.5
  fadeOutDuration: 1.5
  lineGap: 0.6
  predecessorTrailWarmthBump: 12
