  m_text: "\u0633\u064A\u0624\u062F\u064A \u0647\u0630\u0627 \u0625\u0644\u0649 \u0645\u0633\u062D
    \u062A\u0642\u062F\u0651\u0645\u0643 \u0627\u0644\u0645\u062D\u0641\u0648\u0638
