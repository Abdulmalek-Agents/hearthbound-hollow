  m_Script: {fileID: 11500000, guid: 67dedaffe45e24f07b9ae6ed5dc8ba52, type: 3}
  m_Name: 
  m_EditorClassIdentifier: HearthboundHollow.UI::HearthboundHollow.UI.ToneCompassCard
  root: {fileID: 1509941763}
  bodyText: {fileID: 1111843271}
  continueButton: {fileID: 990248239}
  gentleModeToggleButton: {fileID: 0}
  gentleModeToggle: {fileID: 0}
  gentleModeLabel: {fileID: 0}
  defaultBody: 'This game will make you feel things. Some of those feelings are heavy.


    This
    first hour contains: the opening of a shop, a first transaction, a late-night
    brewing.


    The second hour contains: a widower''s grief, a choice about memory,
    a short illustrated dream.


    At any point, you can take a Soft Day, enable
    Gentle Mode, or adjust any settings.


    There is no combat. There are no failure
    screens. There are only choices.


    The cat will be there.'
