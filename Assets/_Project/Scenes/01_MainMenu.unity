--- !u!114 &227445002
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 227445001}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7d3364890e868432d80df2f88be3f161, type: 3}
  m_Name: 
  m_EditorClassIdentifier: HearthboundHollow.UI::HearthboundHollow.UI.MainMenuController
  openTheHollowButton: {fileID: 699219428}
  continueButton: {fileID: 0}
  settingsButton: {fileID: 0}
  creditsButton: {fileID: 0}
  quitButton: {fileID: 2000327590}
  settingsPanel: {fileID: 1690620484}
  creditsPanel: {fileID: 0}
  comfortToolsMenu: {fileID: 1690620486}
  toneCompass: {fileID: 1291375862}
  systemMenu: {fileID: 0}
  firstMissionScene: 03_Mission01_Hollow
  tipLabel: {fileID: 1915523335}
  tips:
  - Some memories want to be sold. Some don't.
  - Polish in slow circles.
  - "Cover all sides \u2014 the orb has four faces."
  - The warm center is the memory itself.
  - Tea opens the way to talk.
  - There is no wrong way to keep a memory.
  - What you choose to remember is what you become.
  tipsAr:
  - "\u0628\u0639\u0636 \u0627\u0644\u0630\u0643\u0631\u064A\u0627\u062A \u062A\u0631\u064A\u062F
    \u0623\u0646 \u062A\u064F\u0628\u0627\u0639. \u0648\u0628\u0639\u0636\u0647\u0627
    \u0644\u0627."
  - "\u0644\u0645\u0651\u0639 \u0628\u062F\u0648\u0627\u0626\u0631 \u0628\u0637\u064A\u0626\u0629."
  - "\u063A\u0637\u0650\u0651 \u0643\u0644 \u0627\u0644\u062C\u0648\u0627\u0646\u0628
    \u2014 \u0644\u0644\u062C\u0648\u0647\u0631\u0629 \u0623\u0631\u0628\u0639\u0629
    \u0623\u0648\u062C\u0647."
  - "\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062F\u0627\u0641\u0626 \u0647\u0648
    \u0627\u0644\u0630\u0643\u0631\u0649 \u0646\u0641\u0633\u0647\u0627."
  - "\u0627\u0644\u0634\u0627\u064A \u064A\u0641\u062A\u062D \u0628\u0627\u0628 \u0627\u0644\u062D\u062F\u064A\u062B."
  - "\u0644\u0627 \u062A\u0648\u062C\u062F \u0637\u0631\u064A\u0642\u0629 \u062E\u0627\u0637\u0626\u0629
    \u0644\u062D\u0641\u0638 \u0630\u0643\u0631\u0649."
  - "\u0645\u0627 \u062A\u062E\u062A\u0627\u0631 \u062A\u0630\u0643\u0651\u0631\u0647
    \u0647\u0648 \u0645\u0627 \u062A\u0635\u064A\u0631 \u0625\u0644\u064A\u0647."
