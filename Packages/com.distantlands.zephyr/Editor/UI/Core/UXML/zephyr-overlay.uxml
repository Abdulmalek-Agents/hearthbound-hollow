<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Packages/com.distantlands.zephyr/Editor/UI/Zephyr.uss?fileID=7433441132597879392&amp;guid=d9081069a744c4346b118e54140b156f&amp;type=3#Zephyr" />
    <ui:VisualElement class="graphRow">
        <ui:VisualElement name="windVelocityGraph" class="windVelocityGraph" style="width: 150px; height: 150px;" />
    </ui:VisualElement>
    <ui:VisualElement>
        <ui:Slider value="0" high-value="5" name="windSlider" style="margin-right: 10px; margin-left: 10px; margin-bottom: 5px;" />
        <ui:VisualElement class="windSpeedSelectorRow" style="flex-grow: 1;">
            <ui:VisualElement tooltip="Still" name="still" style="background-image: resource(&apos;Still&apos;); width: 20px; height: 20px; max-width: 20px; max-height: 20px;" />
            <ui:VisualElement tooltip="Calm" name="calm" style="background-image: resource(&apos;Calm&apos;); width: 20px; height: 20px; max-width: 20px; max-height: 20px;" />
            <ui:VisualElement tooltip="Breezy" name="breezy" style="background-image: resource(&apos;Breezy&apos;); width: 20px; height: 20px; max-width: 20px; max-height: 20px;" />
            <ui:VisualElement tooltip="Strong" name="strong" style="background-image: resource(&apos;Strong&apos;); width: 20px; height: 20px; max-width: 20px; max-height: 20px;" />
            <ui:VisualElement tooltip="Violent" name="violent" style="background-image: resource(&apos;Violent&apos;); width: 20px; height: 20px; max-width: 20px; max-height: 20px;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
